# ⚠️ SECRETS: never commit a filled-in copy. If any value below has ever left a
# secure environment (emailed, zipped, pasted in chat, committed), treat it as
# COMPROMISED and rotate it at the provider. See README "Security & secrets".
# The SERVICE ROLE key bypasses RLS — server-side only, never in client code.

# Supabase (server)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase (browser/auth — anon key is safe to expose; RLS does the guarding)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio — optional in dev; SMS bodies log to the server console when unset
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_BRAND_NUMBER=

# App
APP_BASE_URL=http://localhost:3000
BRAND_NAME=Skin Care Collective
APP_TIMEZONE=America/Chicago
# The single founder/owner login (spec §7). Their magic-link login lands in the console.
FOUNDER_EMAIL=
# Optional: phone that receives concierge escalation texts
FOUNDER_PHONE=
# Optional override; defaults to claude-opus-4-8
CONCIERGE_MODEL=

# Secrets minted by you (any long random string)
# CRON_SECRET gates /api/cron/* — REQUIRED in production. Without it, cron
# routes fail closed (always 401) so jobs silently never run. Vercel/Supabase
# cron must send `Authorization: Bearer $CRON_SECRET`. Generate: openssl rand -hex 24
CRON_SECRET=
LINK_SECRET=

# AI agents (unused until M3)
ANTHROPIC_API_KEY=
